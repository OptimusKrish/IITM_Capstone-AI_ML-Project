# Hospital Intelligence API - Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env file with real secrets to version control!

# ======================
# Application Settings
# ======================
# Model version identifier
MODEL_VERSION=v1.0

# Environment mode: development | production
ENVIRONMENT=development

# ======================
# Logging Configuration
# ======================
# Path to prediction logs (JSONL format)
LOG_FILE=./logs/prediction_logs.jsonl

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ======================
# API Server Configuration
# ======================
# Host to bind to (0.0.0.0 for all interfaces)
API_HOST=127.0.0.1

# Port to run on
API_PORT=8000

# Enable debug mode (development only!)
DEBUG=False

# ======================
# CORS Configuration
# ======================
# Allowed origins for CORS (comma-separated)
# Examples: http://localhost:3000,https://myapp.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Allowed methods
CORS_METHODS=GET,POST,OPTIONS

# Allowed headers
CORS_HEADERS=Content-Type,Authorization

# ======================
# Model Configuration
# ======================
# Path to risk model
RISK_MODEL_PATH=./models/risk_model_v1.pkl

# Path to claim model
CLAIM_MODEL_PATH=./models/claim_model_v1.pkl

# Path to risk model features
RISK_FEATURES_PATH=./models/risk_model_features.pkl

# Path to claim model features
CLAIM_FEATURES_PATH=./models/claim_model_features.pkl

# ======================
# Production Settings
# (Uncomment when deploying to production)
# ======================
# ENVIRONMENT=production
# API_HOST=0.0.0.0
# DEBUG=False
# CORS_ORIGINS=https://yourdomain.com
# LOG_LEVEL=ERROR

# ======================
# Optional: Database (Future Use)
# ======================
# DATABASE_URL=sqlite:///predictions.db
# DATABASE_POOL_SIZE=10

# ======================
# Optional: Authentication (Future Use)
# ======================
# API_KEY=your-secret-api-key-here
# SECRET_KEY=your-jwt-secret-here
# TOKEN_EXPIRY=3600

# ======================
# Optional: External Services (Future Use)
# ======================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# MONITORING_ENDPOINT=https://monitoring.yourservice.com/api/metrics
